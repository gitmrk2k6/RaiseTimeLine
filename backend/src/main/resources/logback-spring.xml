<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- ===== 開発環境（prod 以外） ===== -->
  <springProfile name="!prod">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} %-5level [%X{correlationId:-no-id}] [uid=%X{userId:-anon}] %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
    <logger name="com.raisetimeline" level="DEBUG" additivity="false">
      <appender-ref ref="CONSOLE"/>
    </logger>
  </springProfile>

  <!-- ===== 本番環境（prod） ===== -->
  <springProfile name="prod">

    <!-- JSON コンソール出力（stdout → CloudWatch Logs Agent で収集） -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <fieldNames>
          <timestamp>@timestamp</timestamp>
          <message>message</message>
          <logger>logger</logger>
          <thread>thread</thread>
          <levelValue>[ignore]</levelValue>
        </fieldNames>
        <!-- DataLog でのサービス識別フィールド -->
        <customFields>{"service":"raisetimeline-backend","env":"prod"}</customFields>
        <includeMdcKeyName>correlationId</includeMdcKeyName>
        <includeMdcKeyName>userId</includeMdcKeyName>
        <includeMdcKeyName>method</includeMdcKeyName>
        <includeMdcKeyName>path</includeMdcKeyName>
        <includeMdcKeyName>clientIp</includeMdcKeyName>
      </encoder>
    </appender>

    <!-- ファイル出力 + 日次ローテーション（EC2 ローカルに保存） -->
    <appender name="FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>/var/log/raisetimeline/app.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>/var/log/raisetimeline/app.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
        <maxHistory>30</maxHistory>
        <totalSizeCap>2GB</totalSizeCap>
      </rollingPolicy>
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <customFields>{"service":"raisetimeline-backend","env":"prod"}</customFields>
      </encoder>
    </appender>

    <!-- 非同期ラッパー（I/O ブロッキング防止） -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
      <appender-ref ref="FILE_JSON"/>
      <!-- キュー残量 20% 未満のとき WARN 以下を捨てる（ERROR は捨てない） -->
      <discardingThreshold>20</discardingThreshold>
      <queueSize>512</queueSize>
      <includeCallerData>false</includeCallerData>
    </appender>

    <root level="INFO">
      <appender-ref ref="CONSOLE_JSON"/>
      <appender-ref ref="ASYNC_FILE"/>
    </root>
    <logger name="com.raisetimeline" level="INFO" additivity="false">
      <appender-ref ref="CONSOLE_JSON"/>
      <appender-ref ref="ASYNC_FILE"/>
    </logger>
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="com.raisetimeline.mapper" level="INFO"/>
  </springProfile>

</configuration>
